# ============================================================
# HERMES — Environment Variables Template
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke git
# ============================================================

# --- Database ---
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=hermes
MYSQL_USER=hermes_user
MYSQL_PASSWORD=change_this_db_password
DATABASE_URL=mysql+aiomysql://hermes_user:change_this_db_password@db:3306/hermes

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Encryption ---
# Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HERMES_MASTER_KEY=

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Storage Paths ---
NFS_VIDEOS_PATH=/mnt/omv-videos
NFS_ARCHIVE_PATH=/mnt/omv-archive
NFS_THUMBNAILS_PATH=/mnt/omv-thumbnails
NFS_BACKUPS_PATH=/mnt/omv-backups
STAGING_PATH=/var/staging

# --- App ---
APP_ENV=development
# development | production
SECRET_KEY=change_this_secret_key_for_http_basic_auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_dashboard_password

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Logging ---
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR | CRITICAL

# --- Alerting ---
DISCORD_WEBHOOK_URL=

# --- Google OAuth ---
# OPSI A (direkomendasikan): Letakkan file client_secrets.json di root project
#   Download dari Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
#   Pilih tipe aplikasi: Web application
# OPSI B: Isi env vars di bawah ini (jika tidak pakai client_secrets.json)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- API Bearer Token (opsional) ---
# Untuk akses API endpoints via curl/script tanpa session cookie browser
# Generate dengan: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Jika dikosongkan, hanya session cookie yang diterima
API_BEARER_TOKEN=
